<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h3 mb-0">Movie Details</h1>
      <div>
        <%= link_to "Edit", edit_movie_path(@movie), class: "btn btn-outline-primary shadow-sm" %>
        <%= link_to "Back", movies_path, class: "btn btn-outline-secondary shadow-sm ms-2" %>
        <div class="d-inline-block ms-2">
          <%= button_to "Destroy", @movie, method: :delete, class: "btn btn-danger shadow-sm", data: { turbo_confirm: "Are you sure?" } %>
        </div>
      </div>
    </div>

    <%= render @movie %>
  </div>
</div>
